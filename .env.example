# Auth.js V1 (teacher/member accounts, admin route protection).
# Not provisioned in this environment — required only once a Postgres
# database is set up to run db/migrations/0001_init_auth.sql.

# Postgres connection string (e.g. Vercel Postgres, Neon).
DATABASE_URL=

# Auth.js session secret. Generate with: openssl rand -base64 32
AUTH_SECRET=
