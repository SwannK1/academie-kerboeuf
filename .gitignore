# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# next.js
/.next/
/out/

# builds de validation codex (répertoires temporaires générés localement)
.next-*/
.next-stale-build*/

# production
/build

# misc
.DS_Store
*.pem

# répertoires macOS à noms non portables (deux-points interdit sur Linux/Vercel)
lieux:/
personnages:/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# dist
dist/

# logs génériques
*.log

# projets hors périmètre / répertoires de chantier
kerweb-studio/
components/kerweb/
supabase/

# outillage local Claude Code
.claude/

# documents internes sensibles
docs/audit-request-setup.md
docs/audit-requests-supabase.md

# état runtime de l'espace admin (surcharges + journal local, jamais committé)
data/admin/*.json
