{
  "name": "academie-kerboeuf",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "dev:clean": "rm -rf .next && next dev --webpack",
    "local": "lsof -ti:3000 2>/dev/null | xargs kill -9 2>/dev/null; rm -rf .next && next dev --webpack",
    "open": "open http://localhost:3000",
    "build": "NODE_ENV=production NODE_OPTIONS='--max-old-space-size=4096' next build --webpack",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "next": "16.2.6",
    "next-auth": "^5.0.0-beta.31",
    "pg": "^8.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
